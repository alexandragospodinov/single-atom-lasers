Cell[BoxData[{
 RowBox[{
  RowBox[{"G3mean", "=", 
   FractionBox[
    RowBox[{"4", " ", 
     SuperscriptBox["g", "2"]}], 
    RowBox[{"\[Gamma]12", "+", "\[CapitalGamma]", "+", 
     RowBox[{"2", " ", "\[Kappa]", " ", 
      RowBox[{"(", 
       RowBox[{"n", "-", "0.5", "-", 
        SqrtBox[
         RowBox[{"n", 
          RowBox[{"(", 
           RowBox[{"n", "+", "1"}], ")"}]}]]}], ")"}]}]}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G3mean2", " ", "=", " ", 
   FractionBox[
    RowBox[{"4", " ", 
     SuperscriptBox["g", "2"]}], 
    RowBox[{"\[Gamma]12", "+", "\[CapitalGamma]"}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "=", 
   RowBox[{"\[Gamma]13", "+", "\[Gamma]23", "+", "\[CapitalGamma]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"n", " ", "=", " ", 
   RowBox[{
    FractionBox["\[Gamma]23\[CapitalGamma]", 
     RowBox[{"2", " ", "\[Kappa]", " ", "B"}]], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Gamma]23\[CapitalGamma]", "+", "\[Gamma]12B"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"\[Gamma]13", "+", "\[Gamma]23", "+", 
          RowBox[{
           FractionBox["\[Kappa]", 
            RowBox[{"2", 
             SuperscriptBox["g", "2"]}]], 
           RowBox[{"(", 
            RowBox[{"\[Gamma]12", "+", "\[CapitalGamma]"}], ")"}], "B"}]}], 
         ")"}]}], 
       RowBox[{"\[Gamma]23", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", 
           RowBox[{"(", 
            RowBox[{"\[Gamma]13", "+", "\[Gamma]23"}], ")"}]}], "+", 
          "\[CapitalGamma]"}], ")"}], "\[CapitalGamma]"}]]}], ")"}]}]}], 
  ";"}]}], "Text",
