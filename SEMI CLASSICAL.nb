Cell[TextData[{
 "From the above plot we can see that the threshold occurs at almost ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", "=", 
    RowBox[{"65", 
     SubscriptBox["\[Gamma]", "12"]}]}], TraditionalForm]],ExpressionUUID->
  "70d6f350-c025-43e7-b2a2-e19211b3f14b"],
 " therefore combining figures accordingly"
}], "Text",
