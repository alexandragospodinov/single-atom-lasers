Cell[BoxData[
 RowBox[{
  RowBox[{"Gn", "=", 
   FractionBox[
    RowBox[{"4", " ", 
     SuperscriptBox["g", "2"]}], 
    RowBox[{"\[Gamma]12", "+", "\[CapitalGamma]", "+", 
     RowBox[{"2", " ", "\[Kappa]", " ", 
      RowBox[{"(", 
       RowBox[{"n", "-", 
        FractionBox["1", "2"], "-", 
        SqrtBox[
         RowBox[{"n", 
          RowBox[{"(", 
           RowBox[{"n", "+", "1"}], ")"}]}]]}], ")"}]}]}]]}], ";"}]], "Input",\

