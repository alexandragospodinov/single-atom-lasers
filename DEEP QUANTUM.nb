Cell[BoxData[
 RowBox[{
  RowBox[{"Rst", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"Gn", "/.", 
        RowBox[{"n", "\[Rule]", " ", "0"}]}], ")"}]}], " ", 
     RowBox[{"\[Rho]ss", "[", 
      RowBox[{"4", ",", "4"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Gn", "/.", 
       RowBox[{"n", "\[Rule]", " ", "1"}]}], ")"}], " ", 
